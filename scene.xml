<mujoco model="panda scene">

  <include file="panda.xml"/>

  <statistic center="0.3 0 0.4" extent="1"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6"
               ambient="0.3 0.3 0.3"
               specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient"
             rgb1="0.3 0.5 0.7" rgb2="0 0 0"
             width="512" height="3072"/>

    <texture type="2d" name="groundplane" builtin="checker"
             mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
             markrgb="0.8 0.8 0.8" width="300" height="300"/>

    <material name="groundplane" texture="groundplane"
              texuniform="true" texrepeat="5 5" reflectance="0.2"/>
  </asset>

  <worldbody>

    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>

    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- ===================== CONVEYOR =====================
         Placed at X=0.50 so the robot can reach the cube easily.
    ======================================================= -->
    <body name="conveyor" pos="0.55 0.00 0.35">
      <geom type="box" size="0.25 0.12 0.02" rgba="0.35 0.35 0.35 1"/>
    </body>

    <body name="leg1" pos="0.35  0.10 0.17">
      <geom type="box" size="0.02 0.02 0.17" rgba="0.2 0.2 0.2 1"/>
    </body>
    <body name="leg2" pos="0.75  0.10 0.17">
      <geom type="box" size="0.02 0.02 0.17" rgba="0.2 0.2 0.2 1"/>
    </body>
    <body name="leg3" pos="0.35 -0.10 0.17">
      <geom type="box" size="0.02 0.02 0.17" rgba="0.2 0.2 0.2 1"/>
    </body>
    <body name="leg4" pos="0.75 -0.10 0.17">
      <geom type="box" size="0.02 0.02 0.17" rgba="0.2 0.2 0.2 1"/>
    </body>

    <!-- ===================== CUBES =====================
         Two cubes: red and green.
         Default qpos layout (Panda = 9 joints: 7 arm + 2 finger):
           cube_red   → qpos[9..15]
           cube_green → qpos[16..22]

         Run the debug print at startup to confirm indices.
    ==================================================== -->

    <body name="cube_red" pos="0.55 0.00 0.42">
      <freejoint name="cube_red_joint"/>
      <geom name="cube_red" type="box" size="0.03 0.03 0.03"
            mass="0.10" rgba="1.0 0.0 0.0 1"
            condim="4" friction="1 0.005 0.0001"/>
    </body>

    <body name="cube_green" pos="0.0 0.0 -5.0">
      <freejoint name="cube_green_joint"/>
      <geom name="cube_green" type="box" size="0.03 0.03 0.03"
            mass="0.10" rgba="0.0 1.0 0.0 1"
            condim="4" friction="1 0.005 0.0001"/>
    </body>

    <!-- ===================== SORTING BINS =====================
         Panda base is at origin. Max reliable reach ~0.75m.
         Bins are placed at:
           RED   bin → front-right:  X=0.50, Y=-0.35, Z=0.10
           GREEN bin → front-left:   X=0.50, Y= 0.35, Z=0.10

         Distance from origin:
           RED:   sqrt(0.50²+0.35²) ≈ 0.61 m   ✓ well within reach
           GREEN: sqrt(0.50²+0.35²) ≈ 0.61 m   ✓ well within reach

         Bin floor top surface Z = 0.10 + 0.01 = 0.11
         Cube drop centre Z      = 0.11 + 0.03 = 0.14
    ========================================================== -->

    <!-- RED BIN — front-right -->
    <body name="red_bin" pos="0.50 -0.35 0.10">
      <geom name="red_floor" type="box" size="0.12 0.12 0.01"
            pos="0 0 0"         rgba="0.85 0.15 0.15 1"/>
      <geom name="red_wN"    type="box" size="0.01 0.12 0.06"
            pos=" 0.12 0 0.07"  rgba="0.85 0.15 0.15 0.6"/>
      <geom name="red_wS"    type="box" size="0.01 0.12 0.06"
            pos="-0.12 0 0.07"  rgba="0.85 0.15 0.15 0.6"/>
      <geom name="red_wE"    type="box" size="0.12 0.01 0.06"
            pos="0  0.12 0.07"  rgba="0.85 0.15 0.15 0.6"/>
      <geom name="red_wW"    type="box" size="0.12 0.01 0.06"
            pos="0 -0.12 0.07"  rgba="0.85 0.15 0.15 0.6"/>
    </body>

    <!-- GREEN BIN — front-left -->
    <body name="green_bin" pos="0.50 0.35 0.10">
      <geom name="green_floor" type="box" size="0.12 0.12 0.01"
            pos="0 0 0"         rgba="0.15 0.80 0.15 1"/>
      <geom name="green_wN"    type="box" size="0.01 0.12 0.06"
            pos=" 0.12 0 0.07"  rgba="0.15 0.80 0.15 0.6"/>
      <geom name="green_wS"    type="box" size="0.01 0.12 0.06"
            pos="-0.12 0 0.07"  rgba="0.15 0.80 0.15 0.6"/>
      <geom name="green_wE"    type="box" size="0.12 0.01 0.06"
            pos="0  0.12 0.07"  rgba="0.15 0.80 0.15 0.6"/>
      <geom name="green_wW"    type="box" size="0.12 0.01 0.06"
            pos="0 -0.12 0.07"  rgba="0.15 0.80 0.15 0.6"/>
    </body>

  </worldbody>

</mujoco>